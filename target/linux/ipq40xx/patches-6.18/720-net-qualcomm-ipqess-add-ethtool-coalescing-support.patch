From: OpenWrt IPQ40xx maintainers <openwrt-devel@lists.openwrt.org>
Date: Sun, 12 Jul 2026 00:00:00 +0000
Subject: [PATCH] net: qualcomm: ipqess: add ethtool coalescing support

The EDMA interrupt moderation register has independent 16-bit receive and
transmit timers with a resolution of two microseconds.  The vendor driver
exposed both timers through ethtool, while the current IPQESS driver fixes
them at probe time.

Expose the standard RX/TX coalescing controls.  This allows interrupt rate,
latency and CPU cost to be tuned for the workload.  Preserve the
vendor-derived defaults of 64 usec for RX and 160 usec for TX.

Signed-off-by: OpenWrt IPQ40xx maintainers <openwrt-devel@lists.openwrt.org>
---
 drivers/net/ethernet/qualcomm/ipqess/ipqess.h         |  3 +++
 drivers/net/ethernet/qualcomm/ipqess/ipqess_ethtool.c | 49 +++++++++++++++++++++++++++++++++
 2 files changed, 52 insertions(+)

--- a/drivers/net/ethernet/qualcomm/ipqess/ipqess.h
+++ b/drivers/net/ethernet/qualcomm/ipqess/ipqess.h
@@ -238,6 +238,9 @@ void ipqess_update_hw_stats(struct ipqes
 #define IPQESS_IRQ_MODRT_RX_TIMER_SHIFT 0
 #define IPQESS_IRQ_MODRT_TX_TIMER_SHIFT 16
 
+#define IPQESS_IRQ_MODRT_RESOLUTION_US 2
+#define IPQESS_IRQ_MODRT_MAX_USECS (IPQESS_IRQ_MODRT_TIMER_MASK * IPQESS_IRQ_MODRT_RESOLUTION_US)
+
 /* Interrupt Control Register */
 #define IPQESS_REG_INTR_CTRL 0x284
 #define IPQESS_INTR_CLR_TYP_SHIFT 0
--- a/drivers/net/ethernet/qualcomm/ipqess/ipqess_ethtool.c
+++ b/drivers/net/ethernet/qualcomm/ipqess/ipqess_ethtool.c
@@ -6,6 +6,7 @@
  */
 
 #include <linux/ethtool.h>
+#include <linux/io.h>
 #include <linux/netdevice.h>
 #include <linux/string.h>
 #include <linux/phylink.h>
@@ -147,7 +148,52 @@ static void ipqess_get_ringparam(struct
 	ring->rx_max_pending = IPQESS_RX_RING_SIZE;
 }
 
+static int ipqess_get_coalesce(struct net_device *netdev,
+			       struct ethtool_coalesce *ec,
+			       struct kernel_ethtool_coalesce *kernel_coal,
+			       struct netlink_ext_ack *extack)
+{
+	struct ipqess *ess = netdev_priv(netdev);
+	u32 val;
+
+	val = readl(ess->hw_addr + IPQESS_REG_IRQ_MODRT_TIMER_INIT);
+	ec->rx_coalesce_usecs =
+		((val >> IPQESS_IRQ_MODRT_RX_TIMER_SHIFT) &
+		 IPQESS_IRQ_MODRT_TIMER_MASK) * IPQESS_IRQ_MODRT_RESOLUTION_US;
+	ec->tx_coalesce_usecs =
+		((val >> IPQESS_IRQ_MODRT_TX_TIMER_SHIFT) &
+		 IPQESS_IRQ_MODRT_TIMER_MASK) * IPQESS_IRQ_MODRT_RESOLUTION_US;
+
+	return 0;
+}
+
+static int ipqess_set_coalesce(struct net_device *netdev,
+			       struct ethtool_coalesce *ec,
+			       struct kernel_ethtool_coalesce *kernel_coal,
+			       struct netlink_ext_ack *extack)
+{
+	struct ipqess *ess = netdev_priv(netdev);
+	u32 rx_timer, tx_timer;
+
+	if (ec->rx_coalesce_usecs > IPQESS_IRQ_MODRT_MAX_USECS ||
+	    ec->tx_coalesce_usecs > IPQESS_IRQ_MODRT_MAX_USECS)
+		return -ERANGE;
+
+	rx_timer = DIV_ROUND_UP(ec->rx_coalesce_usecs,
+				IPQESS_IRQ_MODRT_RESOLUTION_US);
+	tx_timer = DIV_ROUND_UP(ec->tx_coalesce_usecs,
+				IPQESS_IRQ_MODRT_RESOLUTION_US);
+
+	writel((tx_timer << IPQESS_IRQ_MODRT_TX_TIMER_SHIFT) |
+	       (rx_timer << IPQESS_IRQ_MODRT_RX_TIMER_SHIFT),
+	       ess->hw_addr + IPQESS_REG_IRQ_MODRT_TIMER_INIT);
+
+	return 0;
+}
+
 static const struct ethtool_ops ipqesstool_ops = {
+	.supported_coalesce_params = ETHTOOL_COALESCE_RX_USECS |
+				     ETHTOOL_COALESCE_TX_USECS,
 	.get_drvinfo = &ipqess_get_drvinfo,
 	.get_link = &ethtool_op_get_link,
 	.get_link_ksettings = &ipqess_get_link_ksettings,
@@ -156,6 +202,8 @@ static const struct ethtool_ops ipqessto
 	.get_sset_count = &ipqess_get_strset_count,
 	.get_ethtool_stats = &ipqess_get_ethtool_stats,
 	.get_ringparam = ipqess_get_ringparam,
+	.get_coalesce = ipqess_get_coalesce,
+	.set_coalesce = ipqess_set_coalesce,
 };
 
 void ipqess_set_ethtool_ops(struct net_device *netdev)
