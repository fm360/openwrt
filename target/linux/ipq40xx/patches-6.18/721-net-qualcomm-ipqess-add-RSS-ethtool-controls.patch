From: OpenWrt IPQ40xx maintainers <openwrt-devel@lists.openwrt.org>
Date: Sun, 12 Jul 2026 00:00:00 +0000
Subject: [PATCH] net: qualcomm: ipqess: add RSS ethtool controls

IPQ4019 EDMA has a 128-entry RSS indirection table and supplies a receive
hash in its return descriptor.  The vendor driver exposed this hash and
allowed table rebalancing.  The current driver instead uses a fixed
four-queue table and discards the descriptor hash.

Report the receive hash when RXHASH is enabled and implement the standard
ethtool RSS indirection callbacks.  EDMA queue IDs are even hardware ring
numbers (0, 2, 4 and 6), so translate them to the four netdev queue indices
at the ethtool boundary.

This makes it possible to reproduce platform-specific CPU isolation with
ethtool -X without carrying private procfs controls.

Signed-off-by: OpenWrt IPQ40xx maintainers <openwrt-devel@lists.openwrt.org>
---
 drivers/net/ethernet/qualcomm/ipqess/ipqess.c         | 16 +++++++++++++---
 drivers/net/ethernet/qualcomm/ipqess/ipqess.h         |  3 +++
 drivers/net/ethernet/qualcomm/ipqess/ipqess_ethtool.c | 70 ++++++++++++++++++++++++++++++++++++++++++++++++++++++
 3 files changed, 86 insertions(+), 3 deletions(-)

--- a/drivers/net/ethernet/qualcomm/ipqess/ipqess.c
+++ b/drivers/net/ethernet/qualcomm/ipqess/ipqess.c
@@ -409,6 +409,15 @@ static int ipqess_rx_poll(struct ipqess_
 			__vlan_hwaccel_put_tag(skb, htons(ETH_P_8021AD),
 					       le16_to_cpu(rd->rrd4));
 
+		if (rx_ring->ess->netdev->features & NETIF_F_RXHASH) {
+			u16 hash_type = le16_to_cpu(rd->rrd5) >> IPQESS_HASH_TYPE_SHIFT;
+
+			if (hash_type > IPQESS_HASH_TYPE_START &&
+			    hash_type < IPQESS_HASH_TYPE_END)
+				skb_set_hash(skb, le16_to_cpu(rd->rrd2),
+					     PKT_HASH_TYPE_L4);
+		}
+
 		if (likely(rx_ring->ess->dsa_ports)) {
 			tag_info = skb_ext_add(skb, SKB_EXT_DSA_OOB);
 			tag_info->port = FIELD_GET(IPQESS_RRD_PORT_ID_MASK,
@@ -1246,9 +1255,10 @@ static int ipqess_axi_probe(struct platf
 	netdev->features = NETIF_F_HW_CSUM | NETIF_F_RXCSUM |
 			   NETIF_F_HW_VLAN_CTAG_RX |
 			   NETIF_F_HW_VLAN_CTAG_TX |
-			   NETIF_F_TSO | NETIF_F_GRO | NETIF_F_SG;
-	/* feature change is not supported yet */
-	netdev->hw_features = 0;
+			   NETIF_F_TSO | NETIF_F_GRO | NETIF_F_SG |
+			   NETIF_F_RXHASH;
+	/* Only RX hash reporting is runtime-switchable. */
+	netdev->hw_features = NETIF_F_RXHASH;
 	netdev->vlan_features = NETIF_F_HW_CSUM | NETIF_F_SG | NETIF_F_RXCSUM |
 				NETIF_F_TSO |
 				NETIF_F_GRO;
--- a/drivers/net/ethernet/qualcomm/ipqess/ipqess.h
+++ b/drivers/net/ethernet/qualcomm/ipqess/ipqess.h
@@ -376,6 +376,9 @@ void ipqess_update_hw_stats(struct ipqes
 #define IPQESS_REG_RSS_IDT(x) (0x840 + ((x) << 2)) /* x = No. of indirection table */
 #define IPQESS_NUM_IDT 16
 #define IPQESS_RSS_IDT_VALUE 0x64206420
+#define IPQESS_RSS_IDT_ENTRIES_PER_REG 8
+#define IPQESS_RSS_IDT_ENTRY_BITS 4
+#define IPQESS_RSS_IDT_SIZE (IPQESS_NUM_IDT * IPQESS_RSS_IDT_ENTRIES_PER_REG)
 
 /* Default RSS Ring Register */
 #define IPQESS_REG_DEF_RSS 0x890
--- a/drivers/net/ethernet/qualcomm/ipqess/ipqess_ethtool.c
+++ b/drivers/net/ethernet/qualcomm/ipqess/ipqess_ethtool.c
@@ -148,6 +148,73 @@ static void ipqess_get_ringparam(struct
 	ring->rx_max_pending = IPQESS_RX_RING_SIZE;
 }
 
+static u32 ipqess_get_rxfh_indir_size(struct net_device *netdev)
+{
+	return IPQESS_RSS_IDT_SIZE;
+}
+
+static int ipqess_get_rxfh(struct net_device *netdev,
+			   struct ethtool_rxfh_param *rxfh)
+{
+	struct ipqess *ess = netdev_priv(netdev);
+	unsigned int i;
+
+	rxfh->hfunc = ETH_RSS_HASH_UNKNOWN;
+
+	if (!rxfh->indir)
+		return 0;
+
+	for (i = 0; i < IPQESS_RSS_IDT_SIZE; i++) {
+		u32 reg = readl(ess->hw_addr +
+				IPQESS_REG_RSS_IDT(i /
+						   IPQESS_RSS_IDT_ENTRIES_PER_REG));
+		u32 ring = (reg >> ((i % IPQESS_RSS_IDT_ENTRIES_PER_REG) *
+				   IPQESS_RSS_IDT_ENTRY_BITS)) &
+			   IPQESS_RSS_RING_ID_MASK;
+
+		if ((ring & 1) || ring >= IPQESS_NETDEV_QUEUES * 2)
+			return -EIO;
+
+		rxfh->indir[i] = ring / 2;
+	}
+
+	return 0;
+}
+
+static int ipqess_set_rxfh(struct net_device *netdev,
+			   struct ethtool_rxfh_param *rxfh,
+			   struct netlink_ext_ack *extack)
+{
+	struct ipqess *ess = netdev_priv(netdev);
+	unsigned int i, j;
+
+	if (rxfh->key || rxfh->hfunc != ETH_RSS_HASH_NO_CHANGE ||
+	    (rxfh->input_xfrm != RXH_XFRM_NO_CHANGE && rxfh->input_xfrm))
+		return -EOPNOTSUPP;
+
+	if (!rxfh->indir)
+		return 0;
+
+	for (i = 0; i < IPQESS_RSS_IDT_SIZE; i++)
+		if (rxfh->indir[i] >= IPQESS_NETDEV_QUEUES)
+			return -EINVAL;
+
+	for (i = 0; i < IPQESS_NUM_IDT; i++) {
+		u32 reg = 0;
+
+		for (j = 0; j < IPQESS_RSS_IDT_ENTRIES_PER_REG; j++) {
+			u32 queue;
+
+			queue = rxfh->indir[i * IPQESS_RSS_IDT_ENTRIES_PER_REG + j];
+			reg |= (queue * 2) << (j * IPQESS_RSS_IDT_ENTRY_BITS);
+		}
+
+		writel(reg, ess->hw_addr + IPQESS_REG_RSS_IDT(i));
+	}
+
+	return 0;
+}
+
 static int ipqess_get_coalesce(struct net_device *netdev,
 			       struct ethtool_coalesce *ec,
 			       struct kernel_ethtool_coalesce *kernel_coal,
@@ -194,6 +261,9 @@ static int ipqess_set_coalesce(struct ne
 static const struct ethtool_ops ipqesstool_ops = {
 	.supported_coalesce_params = ETHTOOL_COALESCE_RX_USECS |
 				     ETHTOOL_COALESCE_TX_USECS,
+	.get_rxfh_indir_size = ipqess_get_rxfh_indir_size,
+	.get_rxfh = ipqess_get_rxfh,
+	.set_rxfh = ipqess_set_rxfh,
 	.get_drvinfo = &ipqess_get_drvinfo,
 	.get_link = &ethtool_op_get_link,
 	.get_link_ksettings = &ipqess_get_link_ksettings,
